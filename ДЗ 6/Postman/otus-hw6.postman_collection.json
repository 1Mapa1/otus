    {
      "name": "Start",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const suffix = `${Date.now()}_${Math.floor(Math.random() * 100000)}`;\r",
              "\r",
              "pm.environment.set(\"user1Login\", `user1_${suffix}`);\r",
              "pm.environment.set(\"user1Password\", `Pass_${suffix}`);\r",
              "pm.environment.set(\"user1Name\", `User One ${suffix}`);\r",
              "\r",
              "pm.environment.set(\"user2Login\", `user2_${suffix}`);\r",
              "pm.environment.set(\"user2Password\", `Pass_${suffix}_2`);\r",
              "pm.environment.set(\"user2Name\", `User Two ${suffix}`);\r",
              "\r",
              "pm.environment.set(\"user1UpdatedName\", `Updated User One ${suffix}`);\r",
              "\r",
              "console.log(\"Generated data:\");\r",
              "console.log({\r",
              "    baseUrl: pm.environment.get(\"baseUrl\"),\r",
              "    user1Login: pm.environment.get(\"user1Login\"),\r",
              "    user1Password: pm.environment.get(\"user1Password\"),\r",
              "    user1Name: pm.environment.get(\"user1Name\"),\r",
              "    user2Login: pm.environment.get(\"user2Login\"),\r",
              "    user2Password: pm.environment.get(\"user2Password\"),\r",
              "    user2Name: pm.environment.get(\"user2Name\"),\r",
              "    user1UpdatedName: pm.environment.get(\"user1UpdatedName\")\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Random test data initialized\", function () {\r",
              "    pm.expect(pm.environment.get(\"user1Login\")).to.exist;\r",
              "    pm.expect(pm.environment.get(\"user2Login\")).to.exist;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
